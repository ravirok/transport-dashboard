# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Required ────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional ────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING

# ── Future real-data integrations ───────────────────────
# WEATHER_API_KEY=       # e.g. OpenWeatherMap
# GEOPOLITICAL_API_KEY=  # e.g. Crisis24 / Dataminr
# FREIGHT_VISIBILITY_API_KEY=  # e.g. project44, FourKites
# CARRIER_DB_API_KEY=    # e.g. Xeneta, Freightos
